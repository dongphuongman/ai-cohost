    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sentry/browser": "^10.48.0",
    "preact": "^10.25.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@preact/preset-vite": "^2.9.0",
    "@types/chrome": "^0.0.287",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^2"
  }
}
