{
  "name": "@ai-cohost/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build --mode development",
    "build:prod": "tsc && vite build --mode production",
